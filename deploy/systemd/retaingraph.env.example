# /opt/retaingraph/shared/retaingraph.env
#
# Copy this file to /opt/retaingraph/shared/retaingraph.env, fill in real values,
# then: chmod 640 retaingraph.env && chown retaingraph:retaingraph retaingraph.env
# Never commit the filled-in version — keep it out of the repo entirely.

# --- Core ---
PORT=4000
NODE_ENV=production

# --- Postgres (Prisma) ---
DATABASE_URL=postgresql://retaingraph:CHANGE_ME@127.0.0.1:5432/retaingraph

# --- Redis (BullMQ queue for the ingest worker) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Cognee ---
# Self-hosted REST server or Cognee Cloud — see ARCHITECTURE.md for the tradeoff.
COGNEE_BASE_URL=http://127.0.0.1:8000
COGNEE_API_KEY=CHANGE_ME
COGNEE_LLM_PROVIDER=groq

# --- Groq ---
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=llama-3.3-70b-versatile

# --- Demo tenant / minimal auth (see scope-discipline note: no real auth this week) ---
DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001
DEMO_API_KEY=CHANGE_ME

# --- Slack webhook simulation ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/ME/PLACEHOLDER

# --- Worker tuning ---
WORKER_CONCURRENCY=4
CHURN_LOOKBACK_HOURS=24
